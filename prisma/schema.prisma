generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  appleId   String   @unique @map("apple_id")
  email     String?
  name        String?
  displayName String?  @unique @map("display_name")
  stepGoal    Int      @default(5000) @map("step_goal")
  lastStepSyncAt DateTime? @map("last_step_sync_at")
  lastSilentPushSentAt DateTime? @map("last_silent_push_sent_at")
  coins     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  steps     Step[]
  sentRequests     Friendship[] @relation("sentRequests")
  receivedRequests Friendship[] @relation("receivedRequests")

  challengesAsUserA  ChallengeInstance[] @relation("challengeUserA")
  challengesAsUserB  ChallengeInstance[] @relation("challengeUserB")
  challengesWon      ChallengeInstance[] @relation("challengeWinner")
  challengesProposed ChallengeInstance[] @relation("challengeProposer")
  deviceTokens       DeviceToken[]
  coinTransactions   CoinTransaction[]

  racesCreated       Race[]              @relation("raceCreator")
  racesWon           Race[]              @relation("raceWinner")
  raceParticipations RaceParticipant[]
  stepSamples        StepSample[]

  @@map("users")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum RelationshipType {
  PARTNER   @map("partner")
  FRIEND    @map("friend")
  FAMILY    @map("family")
}

model Friendship {
  id               String           @id @default(uuid())
  requesterId      String           @map("requester_id")
  addresseeId      String           @map("addressee_id")
  status           FriendshipStatus @default(PENDING)
  relationshipType RelationshipType? @map("relationship_type")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  requester        User             @relation("sentRequests", fields: [requesterId], references: [id])
  addressee        User             @relation("receivedRequests", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

model Step {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  steps     Int
  stepGoal  Int?     @map("step_goal")
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
  @@map("steps")
}

model StepSample {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  steps       Int
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, periodStart])
  @@index([userId, periodStart, periodEnd])
  @@map("step_samples")
}

enum ChallengeType {
  HEAD_TO_HEAD  @map("head_to_head")
  THRESHOLD     @map("threshold")
  CREATIVE      @map("creative")
}

model Challenge {
  id              String        @id @default(uuid())
  title           String
  description     String
  type            ChallengeType
  resolutionRule  String        @map("resolution_rule")
  thresholdValue  Int?          @map("threshold_value")
  active          Boolean       @default(true)
  lastUsedAt      DateTime?     @map("last_used_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  instances       ChallengeInstance[]
  weeklyChallenges WeeklyChallenge[]

  @@map("challenges")
}

model WeeklyChallenge {
  id          String    @id @default(uuid())
  weekOf      DateTime  @unique @db.Date @map("week_of")
  challengeId String    @map("challenge_id")
  droppedAt   DateTime  @default(now()) @map("dropped_at")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  challenge   Challenge @relation(fields: [challengeId], references: [id])

  @@index([challengeId])
  @@map("weekly_challenges")
}

enum StakeStatus {
  PROPOSING  @map("proposing")
  AGREED     @map("agreed")
  SKIPPED    @map("skipped")
}

enum ChallengeInstanceStatus {
  PENDING_STAKE  @map("pending_stake")
  ACTIVE         @map("active")
  COMPLETED      @map("completed")
}

model ChallengeInstance {
  id              String                  @id @default(uuid())
  challengeId     String                  @map("challenge_id")
  weekOf          DateTime                @db.Date @map("week_of")
  userAId         String                  @map("user_a_id")
  userBId         String                  @map("user_b_id")
  stakeId         String?                 @map("stake_id")
  stakeStatus     StakeStatus             @default(PROPOSING) @map("stake_status")
  proposedById    String?                 @map("proposed_by_id")
  proposedStakeId String?                 @map("proposed_stake_id")
  status          ChallengeInstanceStatus @default(PENDING_STAKE)
  winnerUserId    String?                 @map("winner_user_id")
  userATotalSteps Int                     @default(0) @map("user_a_total_steps")
  userBTotalSteps Int                     @default(0) @map("user_b_total_steps")
  resolvedAt      DateTime?               @map("resolved_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  challenge       Challenge               @relation(fields: [challengeId], references: [id])
  userA           User                    @relation("challengeUserA", fields: [userAId], references: [id])
  userB           User                    @relation("challengeUserB", fields: [userBId], references: [id])
  stake           Stake?                  @relation("agreedStake", fields: [stakeId], references: [id])
  proposedStake   Stake?                  @relation("proposedStake", fields: [proposedStakeId], references: [id])
  winner          User?                   @relation("challengeWinner", fields: [winnerUserId], references: [id])
  proposedBy      User?                   @relation("challengeProposer", fields: [proposedById], references: [id])

  @@unique([userAId, userBId, weekOf])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([weekOf])
  @@map("challenge_instances")
}

enum StakeFormat {
  IN_PERSON  @map("in_person")
  VIRTUAL    @map("virtual")
  EITHER     @map("either")
}

model Stake {
  id               String      @id @default(uuid())
  name             String
  description      String?
  category         String
  relationshipTags String[]    @map("relationship_tags")
  format           StakeFormat
  sponsorId        String?     @map("sponsor_id")
  active           Boolean     @default(true)
  createdAt        DateTime    @default(now()) @map("created_at")

  agreedInstances  ChallengeInstance[] @relation("agreedStake")
  proposedInstances ChallengeInstance[] @relation("proposedStake")

  @@map("stakes")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, token])
  @@index([userId])
  @@map("device_tokens")
}

model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int
  reason    String
  refId     String?  @map("ref_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, reason, refId])
  @@map("coin_transactions")
}

enum PowerupType {
  LEG_CRAMP         @map("leg_cramp")
  RED_CARD          @map("red_card")
  SHORTCUT          @map("shortcut")
  COMPRESSION_SOCKS @map("compression_socks")
  PROTEIN_SHAKE     @map("protein_shake")
  RUNNERS_HIGH      @map("runners_high")
  SECOND_WIND       @map("second_wind")
  STEALTH_MODE      @map("stealth_mode")
  WRONG_TURN        @map("wrong_turn")
  FANNY_PACK        @map("fanny_pack")
  TRAIL_MIX         @map("trail_mix")
  DETOUR_SIGN       @map("detour_sign")
  SWITCHEROO        @map("switcheroo")
  MYSTERY_BOX       @map("mystery_box")
}

enum PowerupRarity {
  COMMON    @map("common")
  UNCOMMON  @map("uncommon")
  RARE      @map("rare")
}

enum PowerupStatus {
  MYSTERY_BOX @map("mystery_box")
  QUEUED      @map("queued")
  HELD        @map("held")
  USED        @map("used")
  DISCARDED   @map("discarded")
  EXPIRED     @map("expired")
}

enum ActiveEffectStatus {
  ACTIVE   @map("active_effect")
  EXPIRED  @map("expired_effect")
  BLOCKED  @map("blocked")
}

enum RaceStatus {
  PENDING    @map("pending")
  ACTIVE     @map("active")
  COMPLETED  @map("completed")
  CANCELLED  @map("cancelled")
}

enum RaceParticipantStatus {
  INVITED    @map("invited")
  ACCEPTED   @map("accepted")
  DECLINED   @map("declined")
}

model Race {
  id              String     @id @default(uuid())
  creatorId       String     @map("creator_id")
  name            String
  targetSteps     Int        @map("target_steps")
  status          RaceStatus @default(PENDING)
  maxDurationDays Int        @default(7) @map("max_duration_days")
  startedAt       DateTime?  @map("started_at")
  endsAt          DateTime?  @map("ends_at")
  completedAt     DateTime?  @map("completed_at")
  winnerUserId         String?    @map("winner_user_id")
  powerupsEnabled      Boolean    @default(false) @map("powerups_enabled")
  powerupStepInterval  Int?       @map("powerup_step_interval")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  creator      User              @relation("raceCreator", fields: [creatorId], references: [id])
  winner       User?             @relation("raceWinner", fields: [winnerUserId], references: [id])
  participants RaceParticipant[]
  powerups     RacePowerup[]
  activeEffects RaceActiveEffect[]
  powerupEvents RacePowerupEvent[]

  @@index([creatorId])
  @@index([status])
  @@index([winnerUserId])
  @@map("races")
}

model RaceParticipant {
  id            String                @id @default(uuid())
  raceId        String                @map("race_id")
  userId        String                @map("user_id")
  status        RaceParticipantStatus @default(INVITED)
  totalSteps    Int                   @default(0) @map("total_steps")
  baselineSteps Int                   @default(0) @map("baseline_steps")
  nextBoxAtSteps Int                  @default(0) @map("next_box_at_steps")
  bonusSteps    Int                   @default(0) @map("bonus_steps")
  powerupSlots  Int                   @default(3) @map("powerup_slots")
  placement     Int?
  finishedAt    DateTime?             @map("finished_at")
  joinedAt      DateTime              @default(now()) @map("joined_at")

  race          Race @relation(fields: [raceId], references: [id], onDelete: Cascade)
  user          User @relation(fields: [userId], references: [id])
  powerups      RacePowerup[]
  activeEffectsReceived RaceActiveEffect[]

  @@unique([raceId, userId])
  @@index([userId, status])
  @@index([raceId, status])
  @@map("race_participants")
}

model RacePowerup {
  id            String        @id @default(uuid())
  raceId        String        @map("race_id")
  participantId String        @map("participant_id")
  userId        String        @map("user_id")
  type          PowerupType?
  rarity        PowerupRarity?
  status        PowerupStatus @default(HELD)
  earnedAtSteps Int           @map("earned_at_steps")
  usedAt        DateTime?     @map("used_at")
  targetUserId  String?       @map("target_user_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  race        Race            @relation(fields: [raceId], references: [id], onDelete: Cascade)
  participant RaceParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  activeEffect RaceActiveEffect?

  @@unique([participantId, earnedAtSteps])
  @@index([participantId, status])
  @@index([raceId, userId])
  @@map("race_powerups")
}

model RaceActiveEffect {
  id                  String             @id @default(uuid())
  raceId              String             @map("race_id")
  targetParticipantId String             @map("target_participant_id")
  targetUserId        String             @map("target_user_id")
  sourceUserId        String             @map("source_user_id")
  powerupId           String             @unique @map("powerup_id")
  type                PowerupType
  status              ActiveEffectStatus @default(ACTIVE)
  startsAt            DateTime           @map("starts_at")
  expiresAt           DateTime?          @map("expires_at")
  metadata            Json?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  race              Race            @relation(fields: [raceId], references: [id], onDelete: Cascade)
  targetParticipant RaceParticipant @relation(fields: [targetParticipantId], references: [id], onDelete: Cascade)
  powerup           RacePowerup     @relation(fields: [powerupId], references: [id], onDelete: Cascade)

  @@index([targetParticipantId, status])
  @@index([raceId, status])
  @@map("race_active_effects")
}

model RacePowerupEvent {
  id           String       @id @default(uuid())
  raceId       String       @map("race_id")
  actorUserId  String       @map("actor_user_id")
  eventType    String       @map("event_type")
  powerupType  PowerupType?  @map("powerup_type")
  targetUserId String?      @map("target_user_id")
  description  String
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@index([raceId, createdAt])
  @@map("race_powerup_events")
}
